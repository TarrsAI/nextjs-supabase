# Auto-injected by Tarrs into the dev sandbox. For local dev / Vercel
# prod, paste these from your Supabase project: Settings → API.
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# Server-only — never expose to client. Used in route handlers / server
# actions when you need to bypass RLS.
SUPABASE_SERVICE_ROLE_KEY=
